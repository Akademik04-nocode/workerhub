# Домен приложения (без https://), например workerhub-spb.ru
DOMAIN=

# Telegram
BOT_TOKEN=123456:ABC-DEF...
# Обычно совпадает с https://DOMAIN — установщик заполнит сам
WEBAPP_URL=https://your-mini-app-domain

# База данных
POSTGRES_USER=postgres
# Обязательно задайте свой пароль — compose не поднимется с пустым значением
POSTGRES_PASSWORD=
POSTGRES_DB=workerhub
# Для запуска backend без Docker (в Docker собирается автоматически из значений выше)
DATABASE_URL=postgres://postgres:CHANGE_ME@localhost:5432/workerhub

# Redis (для запуска без Docker)
REDIS_URL=redis://localhost:6379

# Backend
PORT=3000
# Список разрешённых origin через запятую (пусто = разрешить все, только для dev)
CORS_ORIGIN=
# Срок жизни initData в секундах (защита от replay)
INIT_DATA_TTL=86400
# Telegram ID администраторов через запятую (получают роль admin при входе).
# Пусто = ни одного бутстрап-админа. Никогда не коммитьте реальные ID.
ADMIN_TELEGRAM_IDS=

# Frontend
VITE_API_URL=http://localhost:3000
